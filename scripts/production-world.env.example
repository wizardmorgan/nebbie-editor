# Copy to production-world.env and adjust before running export-production-world.sh
#
# Production Nebbie server (source)
PROD_SSH_USER=nebbie
PROD_SSH_HOST=nebbie.nebbie.it
PROD_LIB_REMOTE=Run/release/lib

# Staging / editor host (destination) — nebbie.wizmorgan.it
STAGING_SSH_USER=deploy
STAGING_SSH_HOST=nebbie.wizmorgan.it
STAGING_LIB_REMOTE=/var/www/nebbie/mudroot/lib
STAGING_MANIFEST_REMOTE=/var/www/nebbie/world-manifest.json

# Local working directory (created automatically)
LOCAL_STAGING_DIR=dist/production-world

# rsync/scp options
RSYNC_SSH_OPTS=-o StrictHostKeyChecking=accept-new
FETCH_OVERLAY_DIRS=1
